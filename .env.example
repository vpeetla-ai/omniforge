# OmniForge — self-contained by default. Optional plane connection via LLM_GATEWAY_URL.
APP_ENV=development
OMNIFORGE_MODE=mock
# mock | live  (live uses provider cascade when keys exist)

# Prefer shared plane when set (aegis-llm-gateway). Else in-repo provider cascade / mock.
LLM_GATEWAY_URL=
LLM_GATEWAY_API_KEY=
LLM_GATEWAY_TENANT_ID=omniforge

# Multi-LLM providers (optional — cascade falls through to mock)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GOOGLE_API_KEY=

# Model overrides (optional)
OMNIFORGE_FAST_MODEL=llama-3.3-70b-versatile
OMNIFORGE_STRUCTURED_MODEL=gpt-4o-mini
OMNIFORGE_REASONING_MODEL=claude-sonnet-4-20250514
OMNIFORGE_VISION_MODEL=gpt-4o
OMNIFORGE_GOOGLE_MODEL=gemini-2.0-flash

# Budget (USD) per ask — local FinOps halt
OMNIFORGE_BUDGET_USD=0.50

# Vector memory (optional — in-memory fallback when unset)
QDRANT_URL=
QDRANT_API_KEY=

# Observability (optional)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# Side-effect gate
PRODUCTION_STRICT=false
OMNIFORGE_GATEWAY_FAIL_OPEN=true

# CORS — include your Vercel URL after deploy
CORS_ORIGINS=http://localhost:3000,http://localhost:4173,https://omniforge.vercel.app,https://venkat-ai.com

# Optional FinOps outcome KPI (ADR-029)
AGENTFINOPS_URL=
AGENTFINOPS_API_KEY=
